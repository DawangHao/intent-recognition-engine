  "update_guide": {
    "when_to_update": [
      "添加新技能时",
      "删除现有技能时",
      "修改技能参数时",
      "修改技能API接口时",
      "修改技能呈现形式时"
    ],
    "update_steps": [
      "1. 在 intent_engine/ 目录下创建/更新对应的技能JSON文件（如 CXCK.json、CXDK.json、FQYYZ.json）",
      "2. 更新 app_intent.json 文件，将新技能添加到 Lingxi 的 intent_name 列表中",
      "3. 更新前端 frontend/lingxi/index_v2.html 中的 skillTable 对象",
      "4. 更新本技能清单.json 文件，保持四个字段同步：skill_description、input_parameters、api_endpoint、presentation",
      "5. 测试验证：确保新技能能被正确识别、参数提取、接口调用和结果呈现"
    ],
    "important_notes": [
      "skill_id 必须与 intent_engine/ 目录下的技能JSON文件中的 skill_id 保持一致",
      "input_parameters 必须与技能JSON文件中的 slots 字段保持一致（精简为name、is_required、description）",
      "api_endpoint 必须与前端 skillTable 中的 apiEndpoint 保持一致",
      "presentation 必须与前端 skillTable 中的 uiComponent 保持一致",
      "建议同步更新四个地方：技能JSON文件、app_intent.json、前端skillTable、技能清单.json",
      "每次更新后都需要进行完整测试，确保技能能正常工作"
    ],
    "checklist": {
      "before_update": [
        "确认 skill_id 的唯一性",
        "确认 input_parameters 的完整性和准确性",
        "确认 api_endpoint 的可用性",
        "确认 presentation 的实现（如果需要新增UI组件）"
      ],
      "after_update": [
        "验证技能JSON文件格式正确",
        "验证 app_intent.json 已更新",
        "验证前端 skillTable 已更新",
        "验证技能清单.json 已更新",
        "测试意图识别功能",
        "测试参数提取功能",
        "测试API调用功能",
        "测试结果展示功能"
      ]
    }
  }
