# ===========================================
# 意图识别引擎环境变量配置
# ===========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ----------------------------------------
# 基础配置
# ----------------------------------------
DEBUG=true

# ----------------------------------------
# Redis 配置
# ----------------------------------------
# 是否使用真实 Redis (true/false)
USE_REAL_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password  # 如需密码认证，取消注释并填入

# 上下文缓存过期时间（秒）
CONTEXT_TTL=3600

# ----------------------------------------
# 大模型配置（火山引擎）
# ----------------------------------------
# 必填：火山引擎 API Key
VOLCENGINE_API_KEY=your_api_key_here

# 可选：API 端点（默认使用火山引擎）
VOLCENGINE_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 可选：模型名称
VOLCENGINE_MODEL=doubao-seed-2-0-mini-260215

# 可选：LLM 调用超时时间（秒）
LLM_TIMEOUT=30

# 可选：意图置信度阈值（低于此值视为闲聊）
INTENT_CONFIDENCE_THRESHOLD=0.7

# ----------------------------------------
# LangFuse 可观测性配置
# ----------------------------------------
# 是否启用 LangFuse (true/false)
LANGFUSE_ENABLED=false

# LangFuse 公钥（从 LangFuse 平台获取）
LANGFUSE_PUBLIC_KEY=pk_lf_xxxx

# LangFuse 私钥（从 LangFuse 平台获取）
LANGFUSE_SECRET_KEY=sk_lf_xxxx

# LangFuse 服务器地址（自部署时修改）
LANGFUSE_HOST=https://cloud.langfuse.com
